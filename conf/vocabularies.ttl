# This file is merged into Skosmos configuration for specific
# settings not included in BARTOC terminology registry.

@base <http://bartoc.org/en/node/>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix skosmos: <http://purl.org/net/skosmos#>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.

<15>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true".

<41>
    skosmos:searchByNotation "true" ;
   skosmos:showTopConcepts "true".

<1232>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true";
    void:dataDump <https://www.nomenclature.info/api/dataset/nom?format=TURTLE>.

<192>
    skosmos:searchByNotation "true" ;
    void:dataDump <https://vocabulary.curriculum.edu.au/scot/export/scot.rdf>;
    skosmos:showTopConcepts "true";
    skosmos:defaultLanguage "en".

<475>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true" .

<888>
    skosmos:searchByNotation "true" .

<939>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true" .

<941>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true" ;
    void:dataDump <http://publications.europa.eu/resource/authority/place>.

<954>
    skosmos:searchByNotation "true" ;
    skosmos:showTopConcepts "true" ;
    void:dataDump <http://publications.europa.eu/resource/authority/corporate-body-classification> .

<1961>
    skosmos:searchByNotation "true" ;
    skosmos:defaultLanguage "en";
    void:dataDump <http://vocabulary.semantic-web.at/semweb/export/semweb.ttl> ;
    skosmos:showTopConcepts "true" .

<472>
    skosmos:searchByNotation "true" ;
    void:dataDump <http://www.iskoi.org/ilc/2/skos/ILC2.ttl>.

<18688>
    skosmos:searchByNotation "true" ;
    skosmos:fullAlphabeticalIndex "true";
    void:dataDump <https://www.w3.org/2003/03/glossary-project/data/glossaries/charreq.rdf>.
